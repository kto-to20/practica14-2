rule "Simulate Temperature"
when
    Time cron "0/30 * * * * ?"
then
    val Number temp = (Math::random * 10) + 20
    Temperature.postUpdate(temp)
end


rule "Simulate Light"
when
    Time cron "0/20 * * * * ?"
then
    val Number light = (Math::random * 300)
    LightLevel.postUpdate(light)
end


rule "Ontology-based cooling"
when
    Item Temperature changed
then
    if((Temperature.state as Number) > 25){
        Zigbee_Fan.sendCommand(ON)
    } else {
        Zigbee_Fan.sendCommand(OFF)
    }
end


rule "Ontology-based lighting"
when
    Item LightLevel changed
then
    if((LightLevel.state as Number) < 100){
        Zigbee_Light.sendCommand(ON)
    } else {
        Zigbee_Light.sendCommand(OFF)
    }
end